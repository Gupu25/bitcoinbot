generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Visitor / Anonymous Session ──────────────────────────────────────
model VisitorSession {
  id        String    @id @default(cuid())
  visitorId String?   @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime?

  messages  Message[]
  tips      Tip[]
  feedbacks Feedback[]

  // Relación con immune system
  immuneLogs    ImmuneLog[]
  bypassAttempts BypassAttempt[]

  @@index([createdAt])
  @@index([visitorId])
}

// ── Chat Message ─────────────────────────────────────────────────────
model Message {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  content      String   @db.VarChar(4000)
  role         MessageRole
  tokensUsed   Int?
  metadata     Json?

  session      VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId    String

  @@index([sessionId])
  @@index([createdAt(sort: Desc)])
}

// ── Lightning Tip / Donation ─────────────────────────────────────────
model Tip {
  id             String     @id @default(cuid())
  createdAt      DateTime   @default(now())
  amountSats     Int
  fiatEquivalent Decimal?   @db.Decimal(10, 2)
  memo           String?    @db.VarChar(280)
  
  // Blink-specific fields
  paymentRequest String?    @db.Text
  paymentHash    String?    @unique  // ← Agregado para verificación
  preimage       String?              // Settlement proof
  
  settledAt      DateTime?
  status         TipStatus  @default(PENDING)

  session        VisitorSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  sessionId      String?

  @@index([createdAt])
  @@index([status])
  @@index([paymentHash])  // ← Para lookups rápidos
}

// ── Immune System Logs (NUEVO) ──────────────────────────────────────
model ImmuneLog {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  
  // Identificación
  ip          String
  sessionId   String?
  visitorId   String?
  
  // Threat data
  threatScore Float
  category    String   // injection, sybil, finney, etc.
  signatures  String[] // Array de firmas detectadas
  action      String   // allow, challenge, ban, quarantine
  
  // Metadata
  userAgent   String?  @db.Text
  path        String
  metadata    Json?    // Datos adicionales flexibles
  
  // Relaciones
  session     VisitorSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  
  @@index([createdAt])
  @@index([ip])
  @@index([category])
  @@index([action])
}

// ── Bypass Attempts (NUEVO) ─────────────────────────────────────────
model BypassAttempt {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  
  // Identificación
  ip          String
  sessionId   String?
  
  // Bypass data
  reason      String           // accessibility, mobile, urgency, human
  trustScore  Int              // 0-100
  approved    Boolean
  
  // Interaction data (almacenado como JSON)
  interactionData Json?
  
  // Relaciones
  session     VisitorSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  
  @@index([createdAt])
  @@index([ip])
  @@index([approved])
}

// ── Banned Nodes (NUEVO - Opcional, si quieres persistencia) ─────────
model BannedNode {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  ip          String   @unique
  reason      String
  expiresAt   DateTime
  nodeType    String   @default("byzantine")
  
  // Historial
  previousBans Int     @default(0)
  threatScore  Float?
  
  // Metadata del ban
  signatures  String[]
  path        String?
  
  @@index([expiresAt])
  @@index([ip])
}

// ── Access Tokens (NUEVO - Opcional) ────────────────────────────────
model AccessToken {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  
  token       String   @unique
  method      String   // pow, bypass
  
  // Identificación
  ip          String
  sessionId   String?
  
  // Metadata
  metadata    Json?    // challengeId, trustScore, etc.
  
  @@index([token])
  @@index([expiresAt])
}

// ── User Feedback ────────────────────────────────────────────────────
model Feedback {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())
  type      FeedbackType
  rating    Int?         @default(0)
  message   String?      @db.Text
  helpful   Boolean?

  session   VisitorSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  sessionId String?
}

// ── Enums ────────────────────────────────────────────────────────────
enum MessageRole {
  user
  assistant
  system
}

enum TipStatus {
  PENDING
  SETTLED
  FAILED
  EXPIRED
  CANCELLED
}

enum FeedbackType {
  POSITIVE
  NEGATIVE
  SUGGESTION
  BUG
}

// ============================================
// COMPLIANCE MODULE TABLES
// ============================================

/// Transacciones de propinas recibidas
model ComplianceTransaction {
  id              String   @id @default(uuid())
  
  // Identificación de la transacción
  paymentHash     String   @unique        // Lightning payment hash
  bolt11Invoice   String?                 // Invoice completa (opcional)
  
  // Montos y precios
  amountSats      Int                     // Cantidad en satoshis
  amountBTC       Decimal  @db.Decimal(20, 8)  // BTC equivalente
  amountMXN       Decimal? @db.Decimal(12, 2)  // MXN al momento
  amountUSD       Decimal? @db.Decimal(12, 2)  // USD al momento
  
  // Precios de referencia
  btcPriceMXN     Decimal? @db.Decimal(12, 2)  // Precio BTC en MXN
  btcPriceUSD     Decimal? @db.Decimal(12, 2)  // Precio BTC en USD
  priceSource     String?                 // "coingecko" | "binance" | "manual"
  
  // Metadata
  timestamp       DateTime @default(now())    // Cuándo se recibió
  source          String   @default("lightning") // "lightning" | "onchain" | "manual"
  memo            String?                     // Nota del donante
  sessionId       String?                     // Sesión del usuario (hashed)
  ipHash          String?                     // IP hasheada (GDPR)
  userAgent       String?                     // Browser info
  country         String?                     // País detectado (opcional)
  
  // Estado
  status          String   @default("confirmed") // "pending" | "confirmed" | "failed"
  
  // Trazabilidad
  walletId        String?                     // Wallet que recibió
  settlementDate  DateTime?                   // Cuándo se liquidó
  settlementTx    String?                     // TX de liquidación (si aplica)
  
  // Auditoría
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?                     // Si fue entry manual
  
  // Relaciones
  auditLogs       ComplianceAuditLog[]
  
  @@index([timestamp])
  @@index([status])
  @@index([source])
  @@map("compliance_transactions")
}

/// Log de eventos de auditoría
model ComplianceAuditLog {
  id              String   @id @default(uuid())
  
  // Referencia
  transactionId   String?
  transaction     ComplianceTransaction? @relation(fields: [transactionId], references: [id])
  
  // Evento
  eventType       String                      // "created" | "status_change" | "report_generated" | "manual_entry"
  eventCategory   String                      // "transaction" | "report" | "system" | "admin"
  description     String                      // Descripción del evento
  
  // Detalles
  previousValue   Json?                       // Valor anterior (para cambios)
  newValue        Json?                       // Valor nuevo
  metadata        Json?                       // Datos adicionales
  
  // Actor
  actorType       String   @default("system") // "system" | "admin" | "webhook"
  actorId         String?                     // ID del actor
  actorIP         String?                     // IP del actor
  
  timestamp       DateTime @default(now())
  
  @@index([eventType])
  @@index([eventCategory])
  @@index([timestamp])
  @@map("compliance_audit_logs")
}

/// Reportes fiscales generados
model FiscalReport {
  id              String   @id @default(uuid())
  
  // Identificación
  reportType      String                      // "monthly" | "quarterly" | "annual" | "custom"
  reportPeriod    String                      // "2024-01" | "2024-Q1" | "2024"
  
  // Datos del reporte
  totalSats       Int                         // Total sats recibidos
  totalBTC        Decimal  @db.Decimal(20, 8)
  totalMXN        Decimal  @db.Decimal(12, 2)
  totalUSD        Decimal  @db.Decimal(12, 2)
  
  transactionCount Int                        // Número de transacciones
  
  // Archivo generado
  fileUrl         String?                     // URL al PDF/CSV generado
  fileHash        String?                     // Hash SHA-256 del archivo
  fileType        String?                     // "pdf" | "csv" | "json"
  
  // Estado
  status          String   @default("generated") // "generated" | "submitted" | "acknowledged"
  submittedAt     DateTime?                   // Cuándo se entregó a autoridades
  submittedTo     String?                     // A quién se entregó
  
  // Metadatos
  generatedAt     DateTime @default(now())
  generatedBy     String?                     // Admin que generó
  notes           String?                     // Notas adicionales
  
  @@unique([reportType, reportPeriod])
  @@index([reportType])
  @@index([reportPeriod])
  @@map("fiscal_reports")
}

/// Snapshot diario de balance
model WalletSnapshot {
  id              String   @id @default(uuid())
  
  // Fecha
  date            DateTime @unique            // Fecha del snapshot
  
  // Balances
  lightningBalanceSats   Int                 // Balance Lightning
  onchainBalanceSats     Int?                // Balance on-chain (si aplica)
  totalSats              Int                 // Total
  
  // Valores en fiat
  valueMXN        Decimal  @db.Decimal(12, 2)
  valueUSD        Decimal  @db.Decimal(12, 2)
  
  // Precios de referencia
  btcPriceMXN     Decimal  @db.Decimal(12, 2)
  btcPriceUSD     Decimal  @db.Decimal(12, 2)
  
  // Cambio respecto al día anterior
  changeSats      Int?
  changePercent   Decimal? @db.Decimal(6, 2)
  
  createdAt       DateTime @default(now())
  
  @@index([date])
  @@map("wallet_snapshots")
}

/// Configuración de compliance
model ComplianceSetting {
  id              String   @id @default(uuid())
  
  key             String   @unique            // Nombre del setting
  value           String                      // Valor
  description     String?                     // Descripción
  
  // Auditoría
  updatedAt       DateTime @updatedAt
  updatedBy       String?
  
  @@map("compliance_settings")
}